## Local development environment variables
##
## Copy this file to `.env.local` and fill in values.
## Next.js automatically loads `.env.local` for `next dev`.

# MongoDB connection string
# Example (local):
# MONGODB_URI=mongodb://127.0.0.1:27017/eventvista
#
# Example (Atlas):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/eventvista?retryWrites=true&w=majority
MONGODB_URI=

# JWT secret for signing auth tokens
# Use a long random string in real projects.
JWT_SECRET=dev-secret-eventvista-123
